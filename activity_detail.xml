<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F5F5F5"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="📋 Book Detail"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView android:id="@+id/detailStudent"
            android:textSize="16sp" android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/detailTitle"
            android:textSize="16sp" android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/detailAuthor"
            android:textSize="16sp" android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/detailIssue"
            android:textSize="16sp" android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/detailReturn"
            android:textSize="16sp" android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/detailDays"
            android:textSize="16sp" android:textColor="#E65100"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/detailFine"
            android:textSize="16sp" android:textColor="#C62828"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/detailStatus"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <Button android:id="@+id/markReturnedBtn"
            android:text="✅ Mark as Returned"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button android:id="@+id/deleteBtn"
            android:text="🗑️ Delete Record"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>   
